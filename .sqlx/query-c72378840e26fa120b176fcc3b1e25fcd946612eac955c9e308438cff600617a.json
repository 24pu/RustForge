  "query": "SELECT c.id, c.slug, c.title, c.body, c.published, c.cover_image, c.lang, c.translation_group, c.created_at, c.updated_at\n            FROM contents c\n            JOIN content_categories cc ON c.id = cc.content_id\n            WHERE cc.category_id = $1\n            ORDER BY c.created_at DESC\n            LIMIT $2 OFFSET $3",
