  "query": "SELECT id, slug, title, body, published, cover_image, lang, translation_group, created_at, updated_at\n             FROM contents\n             WHERE title ILIKE $1 OR body ILIKE $1 OR slug ILIKE $1\n             ORDER BY created_at DESC\n             LIMIT $2 OFFSET $3",
